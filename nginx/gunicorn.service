[Unit]
Description=Gunicorn instance to serve FastAPI application
After=network.target

[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/devops-assignment/backend
Environment="PATH=/home/ubuntu/devops-assignment/backend/venv/bin"
ExecStart=/home/ubuntu/devops-assignment/backend/venv/bin/gunicorn \
    -w 2 \
    -k uvicorn.workers.UvicornWorker \
    -b 127.0.0.1:8000 \
    --access-logfile /home/ubuntu/devops-assignment/logs/gunicorn-access.log \
    --error-logfile /home/ubuntu/devops-assignment/logs/gunicorn-error.log \
    app:app

Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
